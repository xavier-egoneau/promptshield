    "test": "vitest run",
    "generate:patterns": "tsx scripts/generate-patterns.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "franc": "^6.2.0",
    "jsdom": "^29.0.2",
    "undici": "^8.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
